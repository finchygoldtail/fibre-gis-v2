NODE_ENV=production
API_HOST=0.0.0.0
API_PORT=3001

# Replace with the deployed frontend origin or staging domain.
CORS_ORIGIN=https://gis.example.com

# Used by README certbot commands and operator notes.
DOMAIN=api.example.com
LETSENCRYPT_EMAIL=admin@example.com

POSTGRES_DB=alistra_gis
POSTGRES_USER=alistra
POSTGRES_PASSWORD=replace-with-a-long-random-secret

# Staging can stay false. Set true before exposing real customer data.
REQUIRE_FIREBASE_AUTH=false
FIREBASE_PROJECT_ID=fibre-gis-v2
